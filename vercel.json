{
  "version": 2,
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@3.9.16",
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "FLASK_APP": "app",
    "FLASK_ENV": "production",
    "PYTHONPATH": "/var/task"
  }
} 